{
  "name": "zync-workspace",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev:client":"cd client && pnpm dev",
    "dev:server":"cd server && pnpm exec nodemon src/index.js",
    "dev":"concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "build":"pnpm --dir client install && pnpm --dir client run build",
    "start":"pnpm --dir server exec node src/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.2",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
